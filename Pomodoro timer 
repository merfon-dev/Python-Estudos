# pomodoro timer 25/5
import time, datetime

# Função para registrar o log
def registrar_log(tarefa, duracao):
    agora = datetime.datetime.now().strftime("%d/%m/%Y %H:%M")
    with open("diario_producao.txt", "a") as arquivo:
        arquivo.write(f"{agora} - Tarefa: {tarefa} - Duração: {duracao} min\n")
    print(f"\nRegistro salvo com sucesso: {tarefa}")

print("Pomodoro Timer")
print("\nEscreva 'pomodoro' para começarmos o trabalho ou 'descanso' para iniciarmos a pausa: ")
resposta = input("> ").lower()
    
if resposta == 'pomodoro':
    nome_tarefa = input("\nEm qual tarefa trabalharemos? ")
    pomodoro = datetime.timedelta(minutes=25)
    print("Pomodoro iniciado!")

    while pomodoro.total_seconds() > 0:
        mins, segs = divmod(pomodoro.seconds, 60)
        print(f"Tempo restante: {mins:02d}:{segs:02d}", end="\r")
        time.sleep(1)
        pomodoro -= datetime.timedelta(seconds=1)

    print("\nTempo esgotado! Hora do descanso.")
    registrar_log(nome_tarefa, 25)

elif resposta == 'descanso':
    descanso = datetime.timedelta(minutes=5)
    print("Descanso iniciado!")
    while descanso.total_seconds() > 0:
        mins, segs = divmod(descanso.total_seconds(), 60)
        print(f"Tempo restante: {int(mins):02d}:{int(segs):02d}", end="\r")
        time.sleep(1)
        descanso -= datetime.timedelta(seconds=1)
        
    print("\nTempo do descanso esgotado. De volta ao trabalho!")
    registrar_log("Descanso", 5)

else:
    print("Operação cancelada.")

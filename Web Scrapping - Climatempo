#Webscrapping - 1o projeto

import requests
from bs4 import BeautifulSoup

url = "https://www.climatempo.com.br/previsao-do-tempo/agora/cidade/323/saquarema-rj" #substituir pra outra cidade

headers = {"User-Agent": "Mozilla/5.0"} # "disfarce" de navegador

resposta = requests.get(url, headers=headers)

if resposta.status_code == 200: #200 - sinal que funcionou perfeitamente
    soup = BeautifulSoup(resposta.text, 'html.parser') # html.parser lê o html bruto e transforma em hierarquia
    
    elemento = soup.find('span', class_='now-forecast-card__temperature') # Aqui procuramos a temperatura atual
    
    if elemento:
        print(f"Temperatura: {elemento.text.strip()}C")
    
    else:
        print("Atenção: O elemento com o ID 'temp-atual' não foi encontrado.")
       
else:
    print(f"Erro na conexão: {resposta.status_code}")
